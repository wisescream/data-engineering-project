{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowReadAnonymizedDataOnly",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject"
            ],
            "Resource": [
                "arn:aws:s3:::insurance-fraud-data/anonymized/*"
            ]
        },
        {
            "Sid": "DenyRawDataAccess",
            "Effect": "Deny",
            "Action": "s3:*",
            "Resource": [
                "arn:aws:s3:::insurance-fraud-data/raw/*"
            ]
        }
    ]
}
